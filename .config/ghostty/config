# Theme
theme = "Catppuccin Mocha"

# Font
font-family = "JetBrainsMono Nerd Font"
font-size = 14
font-thicken = true
font-thicken-strength = 90
font-feature = "-calt,-liga,-dlig"
font-codepoint-map = U+3000-U+303F,U+3040-U+309F,U+30A0-U+30FF,U+31F0-U+31FF,U+3400-U+4DBF,U+4E00-U+9FFF,U+F900-U+FAFF,U+FF00-U+FFEF="Noto Sans Mono CJK JP"

# Window
window-padding-x = 16
window-padding-y = 8
window-padding-balance = true
unfocused-split-opacity = 0.5

# Window behavior
quit-after-last-window-closed = true
confirm-close-surface = true

# Cursor
cursor-style = bar
cursor-style-blink = false

# Input
mouse-hide-while-typing = true
keybind = super+enter=toggle_fullscreen

# Clipboard
copy-on-select = clipboard
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = false

# macOS
macos-option-as-alt = true
macos-titlebar-style = tabs

# Tab/Split
tab-inherit-working-directory = true
split-inherit-working-directory = true

# Shell
shell-integration = fish
