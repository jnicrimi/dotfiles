{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "SHELL": "/opt/homebrew/bin/fish"
  },
  "permissions": {
    "allow": [
      "Bash(cp:*)",
      "Bash(date)",
      "Bash(echo:*)",
      "Bash(git add:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)",
      "Bash(git check-ref-format:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git merge:*)",
      "Bash(git reflog:*)",
      "Bash(git rev-parse:*)",
      "Bash(git shortlog:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(git switch:*)",
      "Bash(ls:*)",
      "Bash(mise run:*)",
      "Bash(mkdir:*)",
      "Bash(pnpm run:*)",
      "Bash(pwd)",
      "Bash(tree:*)",
      "Bash(which:*)",
      "Bash(whoami)",
      "WebSearch"
    ],
    "deny": [
      "Bash(chown:*)",
      "Bash(dd:*)",
      "Bash(git -c:*)",
      "Bash(git config:*)",
      "Bash(git filter-branch:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git remote:*)",
      "Bash(git submodule:*)",
      "Bash(kill:*)",
      "Bash(mkfs:*)",
      "Bash(mysql:*)",
      "Bash(nc:*)",
      "Bash(osascript:*)",
      "Bash(pkill:*)",
      "Bash(psql:*)",
      "Bash(rm -fR:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -Rf:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -R:*)",
      "Bash(rm -r:*)",
      "Bash(rm --recursive:*)",
      "Bash(scp:*)",
      "Bash(security:*)",
      "Bash(ssh:*)",
      "Bash(sudo:*)",
      "Read(.aws/*)",
      "Read(.env*)",
      "Read(.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.env*)",
      "Read(~/.ssh/*)",
      "Read(*credentials*)",
      "Read(*password*)",
      "Read(*secret*)",
      "Write(.env*)",
      "Write(/System/*)",
      "Write(/etc/*)",
      "Write(/usr/*)",
      "Write(~/.aws/*)",
      "Write(~/.ssh/*)",
      "Write(*credentials*)",
      "Write(*password*)",
      "Write(*secret*)"
    ],
    "defaultMode": "plan"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh"
          }
        ]
      }
    ]
  },
  "language": "japanese",
  "alwaysThinkingEnabled": true,
  "showThinkingSummaries": true,
  "effortLevel": "xhigh"
}
